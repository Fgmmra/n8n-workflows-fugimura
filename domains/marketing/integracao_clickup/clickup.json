    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\n// Regex para identificar telefone brasileiro no formato +55 XX XXXXX XXXX\nconst phoneRegex = /\\+55\\s?\\d{2}\\s?\\d{4,5}\\s?\\d{4}/;\n\nfor (const item of items) {\n  const customFields = item.json.custom_fields || [];\n  let telefone = null;\n\n  for (const field of customFields) {\n    if (typeof field.value === 'string' && phoneRegex.test(field.value)) {\n      telefone = field.value.replace(/\\D/g, ''); // remove tudo que não é número\n      break;\n    }\n  }\n\n  results.push({\n    json: {\n      telefone\n    }\n  });\n}\n\nreturn results;\n"
      },
