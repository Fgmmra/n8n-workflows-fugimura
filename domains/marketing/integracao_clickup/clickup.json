    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\n// Regex para detectar telefone internacional BR\nconst phoneRegex = /\\+\\d{1,3}\\s?\\d{2}\\s?\\d{4,5}\\s?\\d{4}/;\n\nfor (const item of items) {\n  const json = item.json;\n\n  let telefone = null;\n  let gestorField = null;\n\n  // Verifica se custom_fields existe\n  if (Array.isArray(json.custom_fields)) {\n\n    for (const field of json.custom_fields) {\n\n      // 1️⃣ Detecta o campo Gestor\n      if (\n        field.name === \"Gestor \" &&\n        field.type === \"users\"\n      ) {\n        gestorField = field;\n      }\n\n      // 2️⃣ Detecta telefone pelo PADRÃO\n      if (field.value && typeof field.value === 'string') {\n        const match = field.value.match(phoneRegex);\n        if (match) {\n          telefone = match[0];\n        }\n      }\n    }\n  }\n\n  const hasNoGestor =\n    !gestorField ||\n    !gestorField.value ||\n    !Array.isArray(gestorField.value) ||\n    gestorField.value.length === 0;\n\n  // Só retorna tarefas sem gestor\n  if (hasNoGestor) {\n    results.push({\n      json: {\n        task_id: json.id || 'N/A',\n        task_name: json.name || 'N/A',\n        telefone: telefone,\n        gestor: null,\n        reason: !gestorField\n          ? 'Campo Gestor não existe'\n          : 'Campo Gestor está vazio'\n      }\n    });\n  }\n}\n\nreturn results;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -192,
        -272
